{
  "name": "webpack-template",
  "version": "1.0.0",
  "description": "A reusable Webpack template for JavaScript projects.",
  "main": "index.js",
  "scripts": {
    "build": "webpack --config webpack.prod.js",
    "dev": "webpack serve --config webpack.dev.js",
    "deploy": "git subtree push --prefix dist origin gh-pages",
    "watch": "webpack --watch --mode development",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "style-loader": "^4.0.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.5"
  }
